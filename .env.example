# Copy this file to .env.local (for local dev) and set values there.
# Production values live in Vercel → Project Settings → Environment Variables.

# ─────────────────────────────────────────────────────────────────
# Preview gate
# ─────────────────────────────────────────────────────────────────
# Gate the whole site behind a coming-soon screen until launch.
# Anyone without the cookie sees /coming-soon. The access link is:
#   https://<your-domain>/?access=<PREVIEW_TOKEN>
# Hitting that URL sets a 90-day cookie on that device.
# To disable the gate entirely (after launch), delete this var.
#
# Generate a strong token, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
PREVIEW_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Supabase (added in Fase 2 of DEPLOY_WORKFLOW.md)
# ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
